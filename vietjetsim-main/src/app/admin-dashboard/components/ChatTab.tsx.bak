'use client';

import React, { useState, useEffect, useRef, useCallback, useMemo } from 'react';
// Supabase removed - using API routes instead
  const supabase = {
    from: () => ({ select: () => ({ eq: () => ({ order: () => Promise.resolve({ data: [], error: null }), single: () => Promise.resolve({ data: null, error: null }), insert: () => Promise.resolve({ data: null, error: null }), update: () => ({ eq: () => Promise.resolve({ error: null }) }), upsert: () => Promise.resolve({ error: null }) }) }),
    channel: () => ({ on: () => ({ on: () => ({ subscribe: () => {} }) }), subscribe: () => {} }),
    removeChannel: () => {},
  };
import { useAuth } from '@/contexts/AuthContext';
import Icon from '@/components/ui/AppIcon';

interface Conversation {
  id: string;
  user_id: string;
  user_email: string;
  user_name: string;
  last_message: string;
  last_message_at: string;
  updated_at?: string;
  unread_by_admin: number;
  unread_by_user: number;
  created_at: string;
}

interface Message {
  id: string;
  conversation_id: string;
  sender_id: string;
  sender_role: string;
  content: string;
  created_at: string;
  read_at: string | null;
}

interface PresenceRow {
  user_id: string;
  conversation_id: string;
  role: string;
  is_online: boolean;
  is_typing: boolean;
  last_seen: string;
}

const CONVS_PER_PAGE = 10;

export default function ChatTab() {
  const { user } = useAuth();
  // Supabase removed - using API routes with polling instead

  const [conversations, setConversations] = useState<Conversation[]>([]);
  const [selectedConv, setSelectedConv] = useState<Conversation | null>(null);
  const [messages, setMessages] = useState<Message[]>([]);
  const [inputText, setInputText] = useState('');
  const [loadingConvs, setLoadingConvs] = useState(true);
  const [loadingMsgs, setLoadingMsgs] = useState(false);
  const [sending, setSending] = useState(false);

  // Sidebar collapsed state for mobile
  const [sidebarOpen, setSidebarOpen] = useState(true);

  // Search / filter / sort state
  const [searchQuery, setSearchQuery] = useState('');
  const [statusFilter, setStatusFilter] = useState<'all' | 'unread' | 'archived'>('all');
  const [sortOrder, setSortOrder] = useState<'latest' | 'oldest'>('latest');

  // Pagination state
  const [currentPage, setCurrentPage] = useState(1);

  // Export state
  const [exportMenuOpen, setExportMenuOpen] = useState(false);
  const [exporting, setExporting] = useState(false);
  const exportMenuRef = useRef<HTMLDivElement>(null);

  // Presence state
  const [userPresence, setUserPresence] = useState<Record<string, PresenceRow>>({});

  const messagesEndRef = useRef<HTMLDivElement>(null);
  const inputRef = useRef<HTMLInputElement>(null);
  const convChannelRef = useRef<any>(null);
  const msgChannelRef = useRef<any>(null);
  const presenceChannelRef = useRef<any>(null);
  const typingTimeoutRef = useRef<ReturnType<typeof setTimeout> | null>(null);

  const scrollToBottom = useCallback(() => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, []);

  // Close export menu on outside click
  useEffect(() => {
    const handleClickOutside = (e: MouseEvent) => {
      if (exportMenuRef.current && !exportMenuRef.current.contains(e.target as Node)) {
        setExportMenuOpen(false);
      }
    };
    document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, []);

  // Upsert admin presence
  const upsertAdminPresence = useCallback(
    async (convId: string, updates: { is_online?: boolean; is_typing?: boolean }) => {
      if (!user) return;
      await supabase.from('chat_presence').upsert(
        {
          user_id: user.id,
          conversation_id: convId,
          role: 'admin',
          last_seen: new Date().toISOString(),
          updated_at: new Date().toISOString(),
          ...updates,
        },
        { onConflict: 'user_id,conversation_id' }
      );
    },
    [user, supabase]
  );

  // Mark user messages as read by admin
  const markUserMessagesRead = useCallback(
    async (convId: string) => {
      // Mark as read via API
      setMessages((prev) =>
        prev.map((m) =>
          m.sender_role === 'user' && !m.read_at ? { ...m, read_at: new Date().toISOString() } : m
        )
      );
    },
    [supabase]
  );

  // Load all conversations
  const loadConversations = useCallback(async () => {
    setLoadingConvs(true);
    try {
      const res = await fetch("/api/chat/conversations");
      const json = await res.json();
      const data = json.conversations || [];
      const error = res.ok ? null : { message: "Failed" };
      if (error) {
        console.error('Load conversations error:', error.message);
        return;
      }
      setConversations(data || []);
    } catch (err) {
      console.error('Load conversations error:', err);
    } finally {
      setLoadingConvs(false);
    }
  }, [supabase]);

  // Load messages for selected conversation
  const loadMessages = useCallback(
    async (convId: string) => {
      setLoadingMsgs(true);
      try {
        const res = await fetch(`/api/chat?conversationId=${convId}`);
        const json = await res.json();
        const data = json.messages || [];
        const error = res.ok ? null : { message: "Failed" };
        if (error) {
          console.error('Load messages error:', error.message);
          return;
        }
        setMessages(data || []);
      } catch (err) {
        console.error('Load messages error:', err);
      } finally {
        setLoadingMsgs(false);
      }
    },
    [supabase]
  );

  // Load presence for all conversations
  const loadAllPresence = useCallback(async () => {
    const { data } = await supabase.from('chat_presence').select('*').eq('role', 'user');
    if (data) {
      const map: Record<string, PresenceRow> = {};
      data.forEach((row: PresenceRow) => {
        if (row.conversation_id) map[row.conversation_id] = row;
      });
      setUserPresence(map);
    }
  }, [supabase]);

  // Subscribe to conversation list changes
  const subscribeToConversations = useCallback(() => {
    if (!supabase) return;
    if (convChannelRef.current) {
      try {
        // removed
      } catch {}
    }
    const channel = supabase
      .channel('admin_conversations')
      .on(
        'postgres_changes',
        { event: '*', schema: 'public', table: 'chat_conversations' },
        (payload: any) => {
          if (payload.eventType === 'INSERT') {
            setConversations((prev) => [payload.new as Conversation, ...prev]);
          } else if (payload.eventType === 'UPDATE') {
            setConversations((prev) =>
              prev
                .map((c) => (c.id === payload.new.id ? (payload.new as Conversation) : c))
                .sort(
                  (a, b) =>
                    new Date(b.updated_at ?? 0).getTime() - new Date(a.updated_at ?? 0).getTime()
                )
            );
            setSelectedConv((prev) =>
              prev?.id === payload.new.id ? (payload.new as Conversation) : prev
            );
          }
        }
      )
      .subscribe();
    convChannelRef.current = channel;
  }, [supabase]);

  // Subscribe to messages in selected conversation
  const subscribeToMessages = useCallback(
    (convId: string) => {
      if (!supabase) return;
      if (msgChannelRef.current) {
        try {
          // removed
        } catch {}
      }
      const channel = supabase
        .channel(`admin_messages_${convId}`)
        .on(
          'postgres_changes',
          {
            event: 'INSERT',
            schema: 'public',
            table: 'chat_messages',
            filter: `conversation_id=eq.${convId}`,
          },
          (payload: any) => {
            const newMsg = payload.new as Message;
            setMessages((prev) => {
              if (prev.find((m) => m.id === newMsg.id)) return prev;
              return [...prev, newMsg];
            });
          }
        )
        .on(
          'postgres_changes',
          {
            event: 'UPDATE',
            schema: 'public',
            table: 'chat_messages',
            filter: `conversation_id=eq.${convId}`,
          },
          (payload: any) => {
            const updated = payload.new as Message;
            setMessages((prev) =>
              prev.map((m) => (m.id === updated.id ? { ...m, read_at: updated.read_at } : m))
            );
          }
        )
        .subscribe();
      msgChannelRef.current = channel;
    },
    [supabase]
  );

  // Subscribe to presence changes
  const subscribeToPresence = useCallback(() => {
    if (!supabase) return;
    if (presenceChannelRef.current) {
      try {
        // removed
      } catch {}
    }
    const channel = supabase
      .channel('admin_presence_all')
      .on(
        'postgres_changes',
        { event: '*', schema: 'public', table: 'chat_presence' },
        (payload: any) => {
          const row = payload.new as PresenceRow;
          if (row?.role === 'user' && row.conversation_id) {
            setUserPresence((prev) => ({ ...prev, [row.conversation_id]: row }));
          }
        }
      )
      .subscribe();
    presenceChannelRef.current = channel;
  }, [supabase]);

  useEffect(() => {
    if (!supabase) return;
    loadConversations();
    loadAllPresence();
    subscribeToConversations();
    subscribeToPresence();
    return () => {
      if (convChannelRef.current) {
        try {
          // removed
        } catch {}
      }
      if (msgChannelRef.current) {
        try {
          // removed
        } catch {}
      }
      if (presenceChannelRef.current) {
        try {
          // removed
        } catch {}
      }
    };
  }, []);

  useEffect(() => {
    if (!supabase || !selectedConv) return;
    loadMessages(selectedConv.id);
    subscribeToMessages(selectedConv.id);
    upsertAdminPresence(selectedConv.id, { is_online: true, is_typing: false });
    markUserMessagesRead(selectedConv.id);
    supabase
      .from('chat_conversations')
      .update({ unread_by_admin: 0 })
      .eq('id', selectedConv.id)
      .then(() => {
        setConversations((prev) =>
          prev.map((c) => (c.id === selectedConv.id ? { ...c, unread_by_admin: 0 } : c))
        );
      });
  }, [selectedConv?.id]);

  useEffect(() => {
    scrollToBottom();
  }, [messages, userPresence]);

  // Reset to page 1 when filters change
  useEffect(() => {
    setCurrentPage(1);
  }, [searchQuery, statusFilter, sortOrder]);

  const handleInputChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    setInputText(e.target.value);
    if (!selectedConv?.id) return;
    upsertAdminPresence(selectedConv.id, { is_online: true, is_typing: true });
    if (typingTimeoutRef.current) clearTimeout(typingTimeoutRef.current);
    typingTimeoutRef.current = setTimeout(() => {
      upsertAdminPresence(selectedConv.id!, { is_online: true, is_typing: false });
    }, 2000);
  };

  const handleSend = async () => {
    if (!inputText.trim() || sending || !user || !selectedConv) return;
    const text = inputText.trim();
    setInputText('');
    setSending(true);
    if (typingTimeoutRef.current) clearTimeout(typingTimeoutRef.current);
    upsertAdminPresence(selectedConv.id, { is_online: true, is_typing: false });
    try {
      const { error } = await supabase.from('chat_messages').insert({
        conversation_id: selectedConv.id,
        sender_id: user.id,
        sender_role: 'admin',
        content: text,
      });
      if (error) {
        console.error('Send error:', error.message);
        setInputText(text);
      }
    } catch (err) {
      console.error('Send error:', err);
      setInputText(text);
    } finally {
      setSending(false);
      setTimeout(() => inputRef.current?.focus(), 50);
    }
  };

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleSend();
    }
  };

  const formatTime = (dateStr: string) => {
    const d = new Date(dateStr);
    const now = new Date();
    const diffMs = now.getTime() - d.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    if (diffMins < 1) return 'Vừa xong';
    if (diffMins < 60) return `${diffMins} phút trước`;
    if (diffMins < 1440)
      return d.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
    return d.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit' });
  };

  const formatMsgTime = (dateStr: string) => {
    return new Date(dateStr).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
  };

  const formatFullDateTime = (dateStr: string) => {
    return new Date(dateStr).toLocaleString('vi-VN', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
  };

  const totalUnread = conversations.reduce((sum, c) => sum + (c.unread_by_admin || 0), 0);
  const getConvPresence = (convId: string) => userPresence[convId];

  // Filtered + sorted conversations
  const filteredConversations = conversations
    .filter((conv) => {
      const q = searchQuery.toLowerCase();
      const matchesSearch =
        !q ||
        (conv.user_name || '').toLowerCase().includes(q) ||
        (conv.user_email || '').toLowerCase().includes(q);
      const matchesStatus =
        statusFilter === 'all' ||
        (statusFilter === 'unread' && conv.unread_by_admin > 0) ||
        (statusFilter === 'archived' && false);
      return matchesSearch && matchesStatus;
    })
    .sort((a, b) => {
      const aTime = new Date(a.last_message_at || a.created_at).getTime();
      const bTime = new Date(b.last_message_at || b.created_at).getTime();
      return sortOrder === 'latest' ? bTime - aTime : aTime - bTime;
    });

  // Pagination
  const totalPages = Math.max(1, Math.ceil(filteredConversations.length / CONVS_PER_PAGE));
  const paginatedConversations = filteredConversations.slice(
    (currentPage - 1) * CONVS_PER_PAGE,
    currentPage * CONVS_PER_PAGE
  );

  // Export CSV
  const exportCSV = useCallback(() => {
    if (!selectedConv || messages.length === 0) return;
    setExporting(true);
    setExportMenuOpen(false);
    try {
      const userName =
        selectedConv.user_name || selectedConv.user_email?.split('@')[0] || 'Khách hàng';
      const headers = ['Thời gian', 'Người gửi', 'Vai trò', 'Nội dung'];
      const rows = messages.map((m) => [
        formatFullDateTime(m.created_at),
        m.sender_role === 'admin' ? 'Admin' : userName,
        m.sender_role === 'admin' ? 'Admin' : 'Người dùng',
        `"${m.content.replace(/"/g, '""')}"`,
      ]);
      const csvContent = [headers.join(','), ...rows.map((r) => r.join(','))].join('\n');
      const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `chat_${userName}_${new Date().toISOString().slice(0, 10)}.csv`;
      a.click();
      URL.revokeObjectURL(url);
    } finally {
      setExporting(false);
    }
  }, [selectedConv, messages]);

  // Export PDF (print-based)
  const exportPDF = useCallback(() => {
    if (!selectedConv || messages.length === 0) return;
    setExporting(true);
    setExportMenuOpen(false);
    try {
      const userName =
        selectedConv.user_name || selectedConv.user_email?.split('@')[0] || 'Khách hàng';
      const msgRows = messages
        .map((m) => {
          const isAdmin = m.sender_role === 'admin';
          const sender = isAdmin ? 'Admin' : userName;
          const align = isAdmin ? 'right' : 'left';
          const bg = isAdmin ? '#ef4444' : '#f3f4f6';
          const color = isAdmin ? '#ffffff' : '#1e293b';
          return `
            <div style="display:flex;justify-content:${isAdmin ? 'flex-end' : 'flex-start'};margin-bottom:10px;">
              <div style="max-width:70%;background:${bg};color:${color};padding:8px 12px;border-radius:12px;font-size:13px;">
                <div style="font-size:10px;color:${isAdmin ? 'rgba(255,255,255,0.7)' : '#6b7280'};margin-bottom:3px;text-align:${align};">${sender} · ${formatFullDateTime(m.created_at)}</div>
                <div>${m.content.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>
              </div>
            </div>`;
        })
        .join('');

      const html = `<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Chat - ${userName}</title>
  <style>
    body { font-family: Arial, sans-serif; padding: 24px; color: #1e293b; }
    h2 { color: #ef4444; margin-bottom: 4px; }
    .meta { color: #6b7280; font-size: 12px; margin-bottom: 20px; }
    .messages { border-top: 1px solid #e5e7eb; padding-top: 16px; }
  </style>
</head>
<body>
  <h2>Lịch sử chat</h2>
  <div class="meta">
    <strong>Người dùng:</strong> ${userName} (${selectedConv.user_email || ''})<br/>
    <strong>Xuất lúc:</strong> ${formatFullDateTime(new Date().toISOString())}<br/>
    <strong>Tổng tin nhắn:</strong> ${messages.length}
  </div>
  <div class="messages">${msgRows}</div>
</body>
</html>`;

      const win = window.open('', '_blank');
      if (win) {
        win.document.write(html);
        win.document.close();
        win.focus();
        setTimeout(() => {
          win.print();
          win.close();
        }, 500);
      }
    } finally {
      setExporting(false);
    }
  }, [selectedConv, messages]);

  return (
    <div
      className="flex h-full bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm relative"
      style={{ minHeight: '600px' }}
    >
      {/* Mobile overlay when sidebar is open */}
      {sidebarOpen && selectedConv && (
        <div
          className="fixed inset-0 bg-black/30 z-10 md:hidden"
          onClick={() => setSidebarOpen(false)}
        />
      )}

      {/* Conversation List Sidebar */}
      <div
        className={`
          flex-shrink-0 border-r border-gray-100 flex flex-col bg-white
          transition-all duration-300 ease-in-out
          md:w-72 md:relative md:translate-x-0 md:z-auto
          ${
            sidebarOpen
              ? 'w-72 absolute inset-y-0 left-0 z-20 translate-x-0'
              : 'w-0 absolute inset-y-0 left-0 z-20 -translate-x-full md:w-72 md:translate-x-0'
          }
        `}
      >
        <div className="w-72 flex flex-col h-full overflow-hidden">
          {/* Header */}
          <div className="px-4 py-4 border-b border-gray-100">
            <div className="flex items-center justify-between">
              <h2 className="font-black text-navy text-base">Hộp thư chat</h2>
              <div className="flex items-center gap-2">
                {totalUnread > 0 && (
                  <span className="bg-primary text-white text-xs font-bold px-2 py-0.5 rounded-full">
                    {totalUnread}
                  </span>
                )}
                {/* Close sidebar button on mobile */}
                <button
                  className="md:hidden w-7 h-7 flex items-center justify-center rounded-lg bg-gray-100 hover:bg-gray-200 transition-colors"
                  onClick={() => setSidebarOpen(false)}
                  aria-label="Đóng danh sách"
                >
                  <Icon name="XMarkIcon" size={14} className="text-gray-600" />
                </button>
              </div>
            </div>
            <p className="text-xs text-gray-400 mt-0.5">
              {filteredConversations.length} cuộc hội thoại
            </p>

            {/* Search bar */}
            <div className="mt-3 flex items-center gap-2 bg-gray-50 rounded-lg px-2.5 py-1.5 border border-gray-200 focus-within:border-primary transition-colors">
              <Icon name="MagnifyingGlassIcon" size={14} className="text-gray-400 flex-shrink-0" />
              <input
                type="text"
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
                placeholder="Tìm tên hoặc email..."
                className="flex-1 bg-transparent text-xs text-navy placeholder-gray-400 outline-none"
              />
              {searchQuery && (
                <button
                  onClick={() => setSearchQuery('')}
                  className="text-gray-400 hover:text-gray-600"
                >
                  <Icon name="XMarkIcon" size={12} />
                </button>
              )}
            </div>

            {/* Status filter pills */}
            <div className="mt-2 flex items-center gap-1">
              {(['all', 'unread', 'archived'] as const).map((s) => (
                <button
                  key={s}
                  onClick={() => setStatusFilter(s)}
                  className={`flex-1 text-xs py-1.5 rounded-md font-medium transition-colors ${
                    statusFilter === s
                      ? 'bg-primary text-white'
                      : 'bg-gray-100 text-gray-500 hover:bg-gray-200'
                  }`}
                >
                  {s === 'all' ? 'Tất cả' : s === 'unread' ? 'Chưa đọc' : 'Lưu trữ'}
                </button>
              ))}
            </div>

            {/* Sort order */}
            <div className="mt-2 flex items-center gap-1.5">
              <Icon name="ArrowsUpDownIcon" size={12} className="text-gray-400" />
              <select
                value={sortOrder}
                onChange={(e) => setSortOrder(e.target.value as 'latest' | 'oldest')}
                className="flex-1 text-xs text-gray-600 bg-gray-50 border border-gray-200 rounded-md px-2 py-1 outline-none focus:border-primary transition-colors"
              >
                <option value="latest">Mới nhất trước</option>
                <option value="oldest">Cũ nhất trước</option>
              </select>
            </div>
          </div>

          {/* List */}
          <div className="flex-1 overflow-y-auto">
            {loadingConvs ? (
              <div className="flex items-center justify-center py-12">
                <div className="w-6 h-6 border-2 border-primary border-t-transparent rounded-full animate-spin" />
              </div>
            ) : filteredConversations.length === 0 ? (
              <div className="flex flex-col items-center justify-center py-12 px-4 text-center">
                <Icon name="ChatBubbleLeftRightIcon" size={32} className="text-gray-300 mb-2" />
                <p className="text-gray-400 text-sm">
                  {searchQuery || statusFilter !== 'all'
                    ? 'Không tìm thấy kết quả'
                    : 'Chưa có cuộc hội thoại nào'}
                </p>
              </div>
            ) : (
              paginatedConversations.map((conv) => {
                const presence = getConvPresence(conv.id);
                const isOnline = presence?.is_online ?? false;
                const isTyping = presence?.is_typing ?? false;
                return (
                  <button
                    key={conv.id}
                    onClick={() => {
                      setSelectedConv(conv);
                      setSidebarOpen(false);
                    }}
                    className={`w-full px-4 py-3.5 flex items-start gap-3 hover:bg-gray-50 active:bg-gray-100 transition-colors border-b border-gray-50 text-left touch-manipulation ${
                      selectedConv?.id === conv.id ? 'bg-red-50 border-l-2 border-l-primary' : ''
                    }`}
                  >
                    <div className="relative w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                      <span className="text-primary font-bold text-sm">
                        {(conv.user_name || conv.user_email || 'K').charAt(0).toUpperCase()}
                      </span>
                      <span
                        className={`absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-white ${
                          isOnline ? 'bg-green-400' : 'bg-gray-300'
                        }`}
                      />
                    </div>
                    <div className="flex-1 min-w-0">
                      <div className="flex items-center justify-between gap-1">
                        <span
                          className={`text-sm truncate ${conv.unread_by_admin > 0 ? 'font-bold text-navy' : 'font-medium text-gray-700'}`}
                        >
                          {conv.user_name || conv.user_email?.split('@')[0] || 'Khách hàng'}
                        </span>
                        <span className="text-xs text-gray-400 flex-shrink-0">
                          {formatTime(conv.last_message_at)}
                        </span>
                      </div>
                      <div className="flex items-center justify-between gap-1 mt-0.5">
                        {isTyping ? (
                          <span className="text-xs text-green-500 font-medium flex items-center gap-1">
                            <span
                              className="w-1 h-1 bg-green-500 rounded-full animate-bounce"
                              style={{ animationDelay: '0ms' }}
                            />
                            <span
                              className="w-1 h-1 bg-green-500 rounded-full animate-bounce"
                              style={{ animationDelay: '150ms' }}
                            />
                            <span
                              className="w-1 h-1 bg-green-500 rounded-full animate-bounce"
                              style={{ animationDelay: '300ms' }}
                            />
                            Đang nhập
                          </span>
                        ) : (
                          <p
                            className={`text-xs truncate ${conv.unread_by_admin > 0 ? 'text-navy font-medium' : 'text-gray-400'}`}
                          >
                            {conv.last_message || 'Bắt đầu cuộc trò chuyện'}
                          </p>
                        )}
                        {conv.unread_by_admin > 0 && (
                          <span className="w-5 h-5 bg-primary text-white text-xs font-bold rounded-full flex items-center justify-center flex-shrink-0">
                            {conv.unread_by_admin > 9 ? '9+' : conv.unread_by_admin}
                          </span>
                        )}
                      </div>
                    </div>
                  </button>
                );
              })
            )}
          </div>

          {/* Pagination */}
          {totalPages > 1 && (
            <div className="flex-shrink-0 border-t border-gray-100 px-3 py-2 flex items-center justify-between gap-1 bg-white">
              <button
                onClick={() => setCurrentPage((p) => Math.max(1, p - 1))}
                disabled={currentPage === 1}
                className="w-8 h-8 flex items-center justify-center rounded-md border border-gray-200 text-gray-500 hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors touch-manipulation"
              >
                <Icon name="ChevronLeftIcon" size={12} />
              </button>
              <div className="flex items-center gap-1">
                {Array.from({ length: totalPages }, (_, i) => i + 1)
                  .filter((p) => p === 1 || p === totalPages || Math.abs(p - currentPage) <= 1)
                  .reduce<(number | string)[]>((acc, p, idx, arr) => {
                    if (idx > 0 && (p as number) - (arr[idx - 1] as number) > 1) acc.push('…');
                    acc.push(p);
                    return acc;
                  }, [])
                  .map((p, idx) =>
                    p === '…' ? (
                      <span key={`ellipsis-${idx}`} className="text-xs text-gray-400 px-0.5">
                        …
                      </span>
                    ) : (
                      <button
                        key={p}
                        onClick={() => setCurrentPage(p as number)}
                        className={`w-8 h-8 flex items-center justify-center rounded-md text-xs font-medium transition-colors touch-manipulation ${
                          currentPage === p
                            ? 'bg-primary text-white'
                            : 'border border-gray-200 text-gray-600 hover:bg-gray-50'
                        }`}
                      >
                        {p}
                      </button>
                    )
                  )}
              </div>
              <button
                onClick={() => setCurrentPage((p) => Math.min(totalPages, p + 1))}
                disabled={currentPage === totalPages}
                className="w-8 h-8 flex items-center justify-center rounded-md border border-gray-200 text-gray-500 hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors touch-manipulation"
              >
                <Icon name="ChevronRightIcon" size={12} />
              </button>
            </div>
          )}
        </div>
      </div>

      {/* Chat Area */}
      <div className="flex-1 flex flex-col min-w-0">
        {!selectedConv ? (
          <div className="flex-1 flex flex-col items-center justify-center text-center gap-4 px-4">
            {/* Mobile: show open sidebar button */}
            <button
              className="md:hidden mb-2 flex items-center gap-2 px-4 py-2.5 bg-primary/10 hover:bg-primary/20 rounded-xl transition-colors touch-manipulation"
              onClick={() => setSidebarOpen(true)}
            >
              <Icon name="ChatBubbleLeftRightIcon" size={18} className="text-primary" />
              <span className="text-sm font-medium text-primary">Xem danh sách hội thoại</span>
            </button>
            <div className="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center">
              <Icon name="ChatBubbleLeftRightIcon" size={32} className="text-primary" />
            </div>
            <div>
              <p className="text-navy font-bold">Chọn cuộc hội thoại</p>
              <p className="text-gray-400 text-sm mt-1">
                Chọn một cuộc hội thoại từ danh sách bên trái
              </p>
            </div>
          </div>
        ) : (
          <>
            {/* Chat Header */}
            <div className="px-4 py-3.5 border-b border-gray-100 flex items-center gap-3 bg-white flex-shrink-0">
              {/* Mobile: back/menu button */}
              <button
                className="md:hidden w-9 h-9 flex items-center justify-center rounded-lg bg-gray-100 hover:bg-gray-200 active:bg-gray-300 transition-colors flex-shrink-0 touch-manipulation"
                onClick={() => setSidebarOpen(true)}
                aria-label="Danh sách hội thoại"
              >
                <Icon name="Bars3Icon" size={18} className="text-gray-600" />
              </button>

              <div className="relative w-9 h-9 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                <span className="text-primary font-bold text-sm">
                  {(selectedConv.user_name || selectedConv.user_email || 'K')
                    .charAt(0)
                    .toUpperCase()}
                </span>
                <span
                  className={`absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-white ${
                    getConvPresence(selectedConv.id)?.is_online ? 'bg-green-400' : 'bg-gray-300'
                  }`}
                />
              </div>
              <div className="min-w-0 flex-1">
                <p className="font-bold text-navy text-sm truncate">
                  {selectedConv.user_name || selectedConv.user_email?.split('@')[0] || 'Khách hàng'}
                </p>
                <div className="flex items-center gap-1.5">
                  {getConvPresence(selectedConv.id)?.is_typing ? (
                    <span className="text-xs text-green-500 font-medium">Đang nhập...</span>
                  ) : (
                    <>
                      <span
                        className={`w-2 h-2 rounded-full flex-shrink-0 ${
                          getConvPresence(selectedConv.id)?.is_online
                            ? 'bg-green-400'
                            : 'bg-gray-300'
                        }`}
                      />
                      <span className="text-xs text-gray-400">
                        {getConvPresence(selectedConv.id)?.is_online
                          ? 'Đang hoạt động'
                          : 'Ngoại tuyến'}
                      </span>
                    </>
                  )}
                </div>
              </div>

              {/* Right side: email + export button */}
              <div className="ml-auto flex items-center gap-2 flex-shrink-0">
                <span className="text-xs text-gray-400 hidden lg:block">
                  {selectedConv.user_email}
                </span>

                {/* Export dropdown */}
                <div className="relative" ref={exportMenuRef}>
                  <button
                    onClick={() => setExportMenuOpen((o) => !o)}
                    disabled={exporting || messages.length === 0}
                    title={
                      messages.length === 0 ? 'Không có tin nhắn để xuất' : 'Xuất lịch sử chat'
                    }
                    className="flex items-center gap-1.5 px-3 py-2 bg-gray-50 hover:bg-gray-100 active:bg-gray-200 border border-gray-200 rounded-lg text-xs font-medium text-gray-600 transition-colors disabled:opacity-40 disabled:cursor-not-allowed touch-manipulation"
                  >
                    {exporting ? (
                      <div className="w-3.5 h-3.5 border-2 border-gray-400 border-t-transparent rounded-full animate-spin" />
                    ) : (
                      <Icon name="ArrowDownTrayIcon" size={14} className="text-gray-500" />
                    )}
                    <span className="hidden sm:inline">Xuất</span>
                    <Icon name="ChevronDownIcon" size={10} className="text-gray-400" />
                  </button>

                  {exportMenuOpen && (
                    <div className="absolute right-0 top-full mt-1 w-44 bg-white border border-gray-200 rounded-xl shadow-lg z-20 overflow-hidden">
                      <div className="px-3 py-2 border-b border-gray-100">
                        <p className="text-xs font-semibold text-gray-500 uppercase tracking-wide">
                          Định dạng xuất
                        </p>
                      </div>
                      <button
                        onClick={exportCSV}
                        className="w-full flex items-center gap-2.5 px-3 py-3 hover:bg-gray-50 active:bg-gray-100 transition-colors text-left touch-manipulation"
                      >
                        <div className="w-7 h-7 bg-green-50 rounded-lg flex items-center justify-center flex-shrink-0">
                          <Icon name="TableCellsIcon" size={14} className="text-green-600" />
                        </div>
                        <div>
                          <p className="text-sm font-medium text-navy">CSV</p>
                          <p className="text-xs text-gray-400">Bảng tính Excel</p>
                        </div>
                      </button>
                      <button
                        onClick={exportPDF}
                        className="w-full flex items-center gap-2.5 px-3 py-3 hover:bg-gray-50 active:bg-gray-100 transition-colors text-left touch-manipulation"
                      >
                        <div className="w-7 h-7 bg-red-50 rounded-lg flex items-center justify-center flex-shrink-0">
                          <Icon name="DocumentTextIcon" size={14} className="text-red-500" />
                        </div>
                        <div>
                          <p className="text-sm font-medium text-navy">PDF</p>
                          <p className="text-xs text-gray-400">In / lưu PDF</p>
                        </div>
                      </button>
                    </div>
                  )}
                </div>
              </div>
            </div>

            {/* Messages */}
            <div className="flex-1 overflow-y-auto px-4 py-4 space-y-3 bg-gray-50">
              {loadingMsgs ? (
                <div className="flex items-center justify-center h-full">
                  <div className="w-6 h-6 border-2 border-primary border-t-transparent rounded-full animate-spin" />
                </div>
              ) : messages.length === 0 ? (
                <div className="flex flex-col items-center justify-center h-full text-center gap-2">
                  <Icon name="ChatBubbleLeftRightIcon" size={28} className="text-gray-300" />
                  <p className="text-gray-400 text-sm">Chưa có tin nhắn nào</p>
                </div>
              ) : (
                messages.map((msg) => {
                  const isAdmin = msg.sender_role === 'admin';
                  return (
                    <div
                      key={msg.id}
                      className={`flex ${isAdmin ? 'justify-end' : 'justify-start'}`}
                    >
                      {!isAdmin && (
                        <div className="relative w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center mr-2 flex-shrink-0 mt-1">
                          <span className="text-primary font-bold text-xs">
                            {(selectedConv.user_name || 'K').charAt(0).toUpperCase()}
                          </span>
                        </div>
                      )}
                      <div
                        className={`max-w-[80%] sm:max-w-[70%] flex flex-col gap-0.5 ${isAdmin ? 'items-end' : 'items-start'}`}
                      >
                        <div
                          className={`px-4 py-2.5 rounded-2xl text-sm leading-relaxed select-text ${
                            isAdmin
                              ? 'bg-primary text-white rounded-br-sm'
                              : 'bg-white text-navy border border-gray-100 rounded-bl-sm shadow-sm'
                          }`}
                        >
                          {msg.content}
                        </div>
                        <div
                          className={`flex items-center gap-1 px-1 ${isAdmin ? 'flex-row-reverse' : 'flex-row'}`}
                        >
                          <span className="text-xs text-gray-400">
                            {formatMsgTime(msg.created_at)}
                          </span>
                          {isAdmin && (
                            <span title={msg.read_at ? 'Đã xem' : 'Đã gửi'}>
                              {msg.read_at ? (
                                <Icon name="CheckCircleIcon" size={12} className="text-blue-400" />
                              ) : (
                                <Icon name="CheckIcon" size={12} className="text-gray-400" />
                              )}
                            </span>
                          )}
                        </div>
                      </div>
                      {isAdmin && (
                        <div className="w-8 h-8 bg-primary rounded-full flex items-center justify-center ml-2 flex-shrink-0 mt-1">
                          <Icon name="ShieldCheckIcon" size={14} className="text-white" />
                        </div>
                      )}
                    </div>
                  );
                })
              )}

              {/* User typing indicator */}
              {getConvPresence(selectedConv.id)?.is_typing && (
                <div className="flex justify-start">
                  <div className="relative w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center mr-2 flex-shrink-0 mt-1">
                    <span className="text-primary font-bold text-xs">
                      {(selectedConv.user_name || 'K').charAt(0).toUpperCase()}
                    </span>
                  </div>
                  <div className="bg-white border border-gray-100 rounded-2xl rounded-bl-sm shadow-sm px-4 py-3 flex items-center gap-1">
                    <span
                      className="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce"
                      style={{ animationDelay: '0ms' }}
                    />
                    <span
                      className="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce"
                      style={{ animationDelay: '150ms' }}
                    />
                    <span
                      className="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce"
                      style={{ animationDelay: '300ms' }}
                    />
                  </div>
                </div>
              )}

              <div ref={messagesEndRef} />
            </div>

            {/* Input */}
            <div className="px-4 py-3 bg-white border-t border-gray-100 flex-shrink-0">
              <div className="flex items-center gap-2 bg-gray-50 rounded-xl px-3 py-2.5 border border-gray-200 focus-within:border-primary transition-colors">
                <input
                  ref={inputRef}
                  type="text"
                  value={inputText}
                  onChange={handleInputChange}
                  onKeyDown={handleKeyDown}
                  placeholder="Nhập phản hồi..."
                  className="flex-1 bg-transparent text-sm text-navy placeholder-gray-400 outline-none min-w-0"
                  disabled={sending}
                />
                <button
                  onClick={handleSend}
                  disabled={!inputText.trim() || sending}
                  className="w-10 h-10 bg-primary disabled:bg-gray-200 rounded-xl flex items-center justify-center transition-colors hover:bg-red-700 active:bg-red-800 disabled:cursor-not-allowed flex-shrink-0 touch-manipulation"
                >
                  {sending ? (
                    <div className="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin" />
                  ) : (
                    <Icon name="PaperAirplaneIcon" size={16} className="text-white" />
                  )}
                </button>
              </div>
            </div>
          </>
        )}
      </div>
    </div>
  );
}
