# ==========================================
# VietjetSim Environment Configuration
# ==========================================
# Copy this file to .env.local and fill in the values:
#   cp .env.local.example .env.local
#
# ⚠️  NEVER commit your .env.local file to version control!
#     It contains real credentials (DB passwords, JWT secrets, API keys).

# ─── Supabase (Optional — legacy, app now uses Neon directly) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Neon PostgreSQL (REQUIRED) ───────────────────────────────────────────
# Get this from your Neon dashboard: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ─── JWT Authentication (REQUIRED) ────────────────────────────────────────
# Generate strong random secrets (at least 32 chars each):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-at-least-32-characters-long

# ─── Application ─────────────────────────────────────────────────────────
# Site URL used for metadata, auth redirects, and sitemaps
NEXT_PUBLIC_SITE_URL=http://localhost:4028

# ─── Development ─────────────────────────────────────────────────────────
Set to 'true' to enable mock auth (bypass for local testing)
NEXT_PUBLIC_USE_MOCK_AUTH=false

# ─── AI / External APIs (Optional) ────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# ─── Analytics (Optional) ────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Neo4j Graph Database (Optional — not actively used) ────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_MAX_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30000
